---
import BaseLayout from '../layouts/BaseLayout.astro';

// Từ điển thuật ngữ Phật học — khởi đầu với các khái niệm căn bản.
const terms = [
  { term: 'Tứ Diệu Đế', def: 'Bốn chân lý cao quý: Khổ, Tập (nguyên nhân khổ), Diệt (chấm dứt khổ), Đạo (con đường diệt khổ). Nền tảng giáo lý nhà Phật.' },
  { term: 'Bát Chánh Đạo', def: 'Con đường tám nhánh dẫn đến giải thoát: chánh kiến, chánh tư duy, chánh ngữ, chánh nghiệp, chánh mạng, chánh tinh tấn, chánh niệm, chánh định.' },
  { term: 'Vô thường (Anicca)', def: 'Mọi sự vật, hiện tượng đều luôn biến đổi, không cố định. Một trong ba đặc tướng của vạn pháp.' },
  { term: 'Vô ngã (Anatta)', def: 'Không có một cái "tôi" thường hằng, độc lập. Mọi thứ do duyên hợp mà thành.' },
  { term: 'Khổ (Dukkha)', def: 'Sự bất toại nguyện, khổ đau vốn có trong đời sống do tham ái và bám chấp.' },
  { term: 'Chánh niệm (Sati)', def: 'Sự tỉnh giác, có mặt trọn vẹn với hiện tại một cách không phán xét.' },
  { term: 'Duyên khởi', def: 'Nguyên lý mọi sự vật phát sinh do các điều kiện (nhân duyên) tương tác; cái này có nên cái kia có.' },
  { term: 'Niết bàn (Nibbana)', def: 'Trạng thái an tịnh tuyệt đối, chấm dứt tham-sân-si và vòng luân hồi khổ đau.' },
  { term: 'Thiểu dục tri túc', def: 'Ít ham muốn và biết đủ — nếp sống giản dị giúp tâm an, giảm khổ.' },
  { term: 'Từ bi', def: 'Từ (mang lại an vui) và Bi (làm vơi khổ đau) cho chúng sinh — phẩm chất cốt lõi của người tu.' },
];
---
<BaseLayout title="Thuật ngữ Phật học" description="Từ điển thuật ngữ Phật học tra cứu nhanh: Tứ Diệu Đế, Bát Chánh Đạo, Vô thường, Duyên khởi…">
  <section class="section container" style="max-width:820px">
    <div class="section-head">
      <div class="eyebrow">📖 Tra cứu</div>
      <h2>Thuật ngữ Phật học</h2>
      <p class="sub">Các khái niệm căn bản, giải thích ngắn gọn dễ hiểu</p>
    </div>
    <div class="prose" data-pagefind-body>
      {terms.map((t) => (
        <div style="border-bottom:1px solid var(--border); padding:1rem 0">
          <h3 style="margin:0 0 0.3rem; color:var(--accent-deep)">{t.term}</h3>
          <p style="margin:0; color:var(--fg-soft)">{t.def}</p>
        </div>
      ))}
    </div>
    <p class="sub" style="margin-top:20px">Từ điển đang được mở rộng dần…</p>
  </section>
</BaseLayout>
