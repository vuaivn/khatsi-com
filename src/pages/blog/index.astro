---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { categories } from '../../config';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Bài viết" description="Luận giải Phật học, tu tập và kinh điển tại thư viện Khất Sĩ.">
  <section class="section container">
    <div class="section-head">
      <div class="eyebrow">Thư viện</div>
      <h2>Tất cả bài viết</h2>
      <p class="sub">Kinh điển · Phật học · Tu tập</p>
    </div>
    <div class="filter">
      <a href="/blog" class="active">Tất cả</a>
      {categories.map((c) => <a href={`/blog/category/${c.slug}`}>{c.name}</a>)}
    </div>
    {posts.length > 0 ? (
      <div class="post-cards">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    ) : (
      <p class="sub" style="text-align:center">Nội dung đang được cập nhật…</p>
    )}
  </section>
</BaseLayout>
